{
  "name": "aitasks",
  "version": "1.3.5",
  "description": "CLI task management tool built for AI agents",
  "type": "module",
  "bin": {
    "aitasks": "./dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --sourcemap=external",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "test": "bun test --timeout 15000",
    "test:watch": "bun test --watch --timeout 15000"
  },
  "keywords": [
    "cli",
    "tasks",
    "task-management",
    "ai",
    "agents",
    "ai-agents",
    "claude",
    "llm"
  ],
  "author": "Sarfraz <sarfraznawaz2005@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/sarfraznawaz2005/aitasks#readme",
  "bugs": {
    "url": "https://github.com/sarfraznawaz2005/aitasks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarfraznawaz2005/aitasks.git"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "react-devtools-core": "^6.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.10",
    "typescript": "^5.7.3"
  }
}
